# ============================================
# STRIPE CONFIGURATION TEMPLATE
# Copy this and fill in your actual values
# ============================================

# ===== STRIPE API KEYS =====
# Get from: https://dashboard.stripe.com/apikeys
# For LIVE: Copy your sk_live_... key
# For TESTING: Copy your sk_test_... key

STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY_HERE

# Get from: https://dashboard.stripe.com/apikeys
# For LIVE: Copy your pk_live_... key
# For TESTING: Copy your pk_test_... key

STRIPE_PUBLIC_KEY=YOUR_STRIPE_PUBLIC_KEY_HERE

# ===== STRIPE PRODUCT PRICE IDS =====
# Get from: https://dashboard.stripe.com/products
# Click each product → copy the Price ID (starts with "price_")

# Starter: £27.99/month
STRIPE_PRICE_STARTER=YOUR_STARTER_PRICE_ID_HERE

# Core: £47.00/month
STRIPE_PRICE_CORE=YOUR_CORE_PRICE_ID_HERE

# Premium: £97.00/month
STRIPE_PRICE_PREMIUM=YOUR_PREMIUM_PRICE_ID_HERE

# ===== STRIPE WEBHOOK SECRET =====
# Get from: https://dashboard.stripe.com/webhooks
# Click your webhook endpoint → copy the Signing secret

STRIPE_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET_HERE

# ===== APP CONFIGURATION =====
# This is your application URL
NEXT_PUBLIC_APP_URL=https://socialposter.easy-ai.co.uk

# ============================================
# INSTRUCTIONS:
# ============================================
# 1. Go to https://dashboard.stripe.com
# 2. Get your API keys from Settings → API Keys
# 3. Create 3 products with the pricing above
# 4. Copy each Price ID and paste here
# 5. Create webhook endpoint for /api/stripe/webhook
# 6. Copy the webhook signing secret
# 7. Replace all values above
# 8. Save as .env.local (for local dev) or add to hosting
