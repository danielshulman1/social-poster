{
    "buildCommand": "pnpm --filter social-feeds build",
    "outputDirectory": "packages/social-feeds/.next",
    "installCommand": "pnpm install --config.engine-strict=false",
    "framework": "nextjs",
    "devCommand": "cd packages/social-feeds && pnpm dev",
    "crons": [
        {
            "path": "/api/cron/process-schedules",
            "schedule": "0 0 * * *"
        }
    ]
}
