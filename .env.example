# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DATABASE_URL="postgresql://user:password@localhost:5432/ai_operations_platform"
DIRECT_URL="postgresql://user:password@localhost:5432/ai_operations_platform"

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
# Generate JWT_SECRET with: openssl rand -base64 32
JWT_SECRET="your-secure-jwt-secret-here-min-32-chars"

# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_SECRET="your-nextauth-secret-here-min-32-chars"

NEXTAUTH_URL="http://localhost:3000"
NODE_ENV="development"

# ============================================================================
# ALLOWED ORIGINS (for CORS) - comma separated
# ============================================================================
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001"

# ============================================================================
# API CONFIGURATION
# ============================================================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
PORT=3000

# ============================================================================
# DATABASE ENCRYPTION (for production)
# ============================================================================
# Master encryption key - store in AWS KMS / HashiCorp Vault in production
# DO NOT commit this to git
MASTER_ENCRYPTION_KEY="your-encryption-key-here"

# ============================================================================
# SOCIAL PLATFORM OAUTH CREDENTIALS
# ============================================================================
# These should come from:
# - Facebook: https://developers.facebook.com/apps
# - Google: https://console.cloud.google.com/apis/credentials
# - LinkedIn: https://www.linkedin.com/developers/apps
# - Twitter/X: https://developer.twitter.com/en/portal/dashboard
# - TikTok: https://developers.tiktok.com
# - YouTube: https://console.cloud.google.com/
# - Pinterest: https://developers.pinterest.com/

FACEBOOK_APP_ID="your_facebook_app_id"
FACEBOOK_APP_SECRET="your_facebook_app_secret"

GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
GOOGLE_SHEETS_CLIENT_ID="your_google_sheets_client_id"
GOOGLE_SHEETS_CLIENT_SECRET="your_google_sheets_client_secret"

LINKEDIN_CLIENT_ID="your_linkedin_client_id"
LINKEDIN_CLIENT_SECRET="your_linkedin_client_secret"

TWITTER_CLIENT_ID="your_twitter_client_id"
TWITTER_CLIENT_SECRET="your_twitter_client_secret"

TIKTOK_CLIENT_ID="your_tiktok_client_id"
TIKTOK_CLIENT_SECRET="your_tiktok_client_secret"

YOUTUBE_CLIENT_ID="your_youtube_client_id"
YOUTUBE_CLIENT_SECRET="your_youtube_client_secret"

PINTEREST_CLIENT_ID="your_pinterest_client_id"
PINTEREST_CLIENT_SECRET="your_pinterest_client_secret"

# ============================================================================
# AI PROVIDER API KEYS
# ============================================================================
# Important: Users provide their own keys via settings UI
# Do NOT commit actual keys to this file

# OpenAI - Users add their own
# OPENAI_API_KEY should NOT be in .env - users provide via UI

# OpenRouter (alternative)
# OPENROUTER_API_KEY should NOT be in .env - users provide via UI

# ============================================================================
# EMAIL SERVICE (Resend)
# ============================================================================
# Get from: https://resend.com/api-keys
RESEND_API_KEY="your_resend_api_key"

# ============================================================================
# BUILD OPTIMIZATION (Optional for Vercel)
# ============================================================================
NX_DAEMON="false"
TURBO_CACHE="remote:rw"
TURBO_DOWNLOAD_LOCAL_ENABLED="true"

# ============================================================================
# MONITORING & LOGGING
# ============================================================================
SENTRY_DSN="your_sentry_dsn"
LOG_LEVEL="info"

# ============================================================================
# RATE LIMITING
# ============================================================================
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX_REQUESTS="100"
RATE_LIMIT_AUTH_WINDOW_MS="60000"
RATE_LIMIT_AUTH_MAX_REQUESTS="5"
